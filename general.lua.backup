-- Kill feed lines (max 6)
local MAX_KILLFEED = 6
local KillFeedDrawings = {}
for i = 1, MAX_KILLFEED do
    local txt = Drawing.new("Text")
    txt.Visible = false
    txt.Size = 14
    txt.Color = Color3.new(1, 1, 1)
    txt.Outline = true
    txt.Text = ""
    KillFeedDrawings[i] = txt
end

-- ============================================
-- Cleanup
-- ============================================
local function Terminate()
    for _, conn in ipairs(ActiveConnections) do
        if conn.Connected then pcall(function() conn:Disconnect() end) end
    end
    table.clear(ActiveConnections)
    pcall(function() RunService:UnbindFromRenderStep("AutoAimLoop") end)

    local allDrawings = {FOVCircle, DiagnosticText, TargetInfoText, TargetHealthBG, TargetHealthFill, HitMarker, LockIndicator}
    for _, d in ipairs(allDrawings) do pcall(function() d:Remove() end) end
    for _, d in ipairs(KillFeedDrawings) do pcall(function() d:Remove() end) end
    -- Clean up ESP drawings
    for plr, cache in pairs(ESPCache) do
        for _, drawing in pairs(cache) do
            pcall(function() drawing:Remove() end)
        end
    end
    table.clear(ESPCache)
end

-- ============================================
-- Kill Feed
-- ============================================
local function AddKillFeedEntry(text, color)
    table.insert(KillFeedEntries, 1, {
        text = text,
        time = tick(),
        color = color or Color3.new(1, 1, 1)
    })
    if #KillFeedEntries > MAX_KILLFEED then
        table.remove(KillFeedEntries, MAX_KILLFEED + 1)
    end
end

-- ============================================
-- Remote Hooks
-- ============================================
task.spawn(function()
    task.wait(2)

    -- GameService.Killed → Kill feed + K/D tracking
    local killedRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "GameClient", "Killed")
    if killedRemote and killedRemote:IsA("RemoteEvent") then
        RegisterConnection(killedRemote.OnClientEvent:Connect(function(...)
            local args = {...}
            pcall(function()
                local killer, victim = "?", "?"
                if typeof(args[1]) == "Instance" and args[1]:IsA("Player") then killer = args[1].Name
                elseif type(args[1]) == "string" then killer = args[1]
                elseif typeof(args[1]) == "Instance" then killer = args[1].Name end
                if typeof(args[2]) == "Instance" and args[2]:IsA("Player") then victim = args[2].Name
                elseif type(args[2]) == "string" then victim = args[2]
                elseif typeof(args[2]) == "Instance" then victim = args[2].Name end

                local color = Color3.new(1, 1, 1)
                if killer == LocalPlayer.Name then
                    KillCount = KillCount + 1
                    color = Color3.fromRGB(50, 255, 50)
                elseif victim == LocalPlayer.Name then
                    DeathCount = DeathCount + 1
                    color = Color3.fromRGB(255, 50, 50)
                end
                AddKillFeedEntry(killer .. " ▸ " .. victim, color)
            end)
            if Config.RemoteLogEnabled then
                table.insert(RemoteLog, 1, {name = "Killed", time = tick()})
                if #RemoteLog > 50 then table.remove(RemoteLog, 51) end
            end
        end))
    end

    -- GameService.Assist
    local assistRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "GameClient", "Assist")
    if assistRemote and assistRemote:IsA("RemoteEvent") then
        RegisterConnection(assistRemote.OnClientEvent:Connect(function()
            AssistCount = AssistCount + 1
            AddKillFeedEntry("ASSIST!", Color3.fromRGB(100, 200, 255))
        end))
    end

    -- EntityService.BeDamaged → Hit marker
    local beDamagedRemote = SafeFind(ReplicatedStorage, "Remote", "EntityService", "BeDamaged")
    if beDamagedRemote and beDamagedRemote:IsA("RemoteEvent") then
        RegisterConnection(beDamagedRemote.OnClientEvent:Connect(function(...)
            HitMarkerTime = tick()
            if Config.RemoteLogEnabled then
                table.insert(RemoteLog, 1, {name = "BeDamaged", time = tick()})
                if #RemoteLog > 50 then table.remove(RemoteLog, 51) end
            end
        end))
    end

    -- EntityService.Died → Death detection
    local diedRemote = SafeFind(ReplicatedStorage, "Remote", "EntityService", "Died")
    if diedRemote and diedRemote:IsA("RemoteEvent") then
        RegisterConnection(diedRemote.OnClientEvent:Connect(function(...)
            local args = {...}
            pcall(function()
                if typeof(args[1]) == "Instance" then
                    if args[1] == LocalPlayer.Character or args[1] == LocalPlayer then
                        IsAlive = false
                        DeathTime = tick()
                    end
                end
            end)
        end))
    end

    -- EntityService.Spawned → Respawn detection
    local spawnedRemote = SafeFind(ReplicatedStorage, "Remote", "EntityService", "Spawned")
    if spawnedRemote and spawnedRemote:IsA("RemoteEvent") then
        RegisterConnection(spawnedRemote.OnClientEvent:Connect(function(...)
            local args = {...}
            pcall(function()
                if typeof(args[1]) == "Instance" then
                    if args[1] == LocalPlayer.Character or args[1] == LocalPlayer then
                        IsAlive = true
                        AddKillFeedEntry("Respawned", Color3.fromRGB(50, 200, 255))
                    end
                end
            end)
        end))
    end

    -- GameService.WeaponPickup
    local wpRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "WeaponPickup")
    if wpRemote and wpRemote:IsA("RemoteEvent") then
        RegisterConnection(wpRemote.OnClientEvent:Connect(function()
            AddKillFeedEntry("⚔ Weapon Pickup", Color3.fromRGB(255, 200, 50))
        end))
    end

    -- GameService.RoomManager.Room.GameStarted → Reset stats
    local gsRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "RoomManager", "Room", "GameStarted")
    if gsRemote and gsRemote:IsA("RemoteEvent") then
        RegisterConnection(gsRemote.OnClientEvent:Connect(function()
            KillCount, DeathCount, AssistCount = 0, 0, 0
            AddKillFeedEntry("— GAME STARTED —", Color3.fromRGB(255, 255, 100))
        end))
    end

    -- GameService.RoomManager.Room.GameEnded → Score summary
    local geRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "RoomManager", "Room", "GameEnded")
    if geRemote and geRemote:IsA("RemoteEvent") then
        RegisterConnection(geRemote.OnClientEvent:Connect(function()
            AddKillFeedEntry(string.format("GAME OVER  K:%d D:%d A:%d", KillCount, DeathCount, AssistCount), Color3.fromRGB(255, 200, 50))
        end))
    end

    -- GameService.RoomManager.Room.RoundStarted
    local rsRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "RoomManager", "Room", "RoundStarted")
    if rsRemote and rsRemote:IsA("RemoteEvent") then
        RegisterConnection(rsRemote.OnClientEvent:Connect(function()
            AddKillFeedEntry("— ROUND START —", Color3.fromRGB(180, 180, 255))
        end))
    end

    -- GameMode.Duel.Winner
    local dwRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "GameMode", "Duel", "Winner")
    if dwRemote and dwRemote:IsA("RemoteEvent") then
        RegisterConnection(dwRemote.OnClientEvent:Connect(function(...)
            local args = {...}
            pcall(function()
                local w = "Unknown"
                if typeof(args[1]) == "Instance" then w = args[1].Name
                elseif type(args[1]) == "string" then w = args[1] end
                local c = (w == LocalPlayer.Name) and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 150, 50)
                AddKillFeedEntry("DUEL WINNER: " .. w, c)
            end)
        end))
    end

    -- TeamService.UpdateData → Capture team assignments
    local teamUpdateRemote = SafeFind(ReplicatedStorage, "Remote", "TeamService", "UpdateData")
    if teamUpdateRemote and teamUpdateRemote:IsA("RemoteEvent") then
        RegisterConnection(teamUpdateRemote.OnClientEvent:Connect(function(...)
            local args = {...}
            -- Store raw data for the scanner to inspect
            TeamDataRaw = args
            pcall(function()
                -- Try common data formats:
                -- Format 1: {playerName = teamId, ...}
                -- Format 2: {members = {playerName, ...}, teamId = X}
                -- Format 3: table with nested player-team mappings
                if type(args[1]) == "table" then
                    for k, v in pairs(args[1]) do
                        if type(k) == "string" then
                            -- Could be playerName = teamId
                            TeamData[k] = tostring(v)
                        end
                    end
                end
            end)
            if Config.RemoteLogEnabled then
                table.insert(RemoteLog, 1, {name = "TeamService.UpdateData", time = tick(), argCount = #args})
                if #RemoteLog > 50 then table.remove(RemoteLog, 51) end
            end
        end))
    end

    -- EntityService.WalkSpeed → Log speed changes
    local wsRemote = SafeFind(ReplicatedStorage, "Remote", "EntityService", "WalkSpeed")
    if wsRemote and wsRemote:IsA("RemoteEvent") then
        RegisterConnection(wsRemote.OnClientEvent:Connect(function(...)
            if Config.RemoteLogEnabled then
                table.insert(RemoteLog, 1, {name = "WalkSpeed", time = tick()})
                if #RemoteLog > 50 then table.remove(RemoteLog, 51) end
            end
        end))
    end

    -- GameClient.RoleChanged → Notify role assignment + store role
    local rcRemote = SafeFind(ReplicatedStorage, "Remote", "GameService", "GameClient", "RoleChanged")
    if rcRemote and rcRemote:IsA("RemoteEvent") then
        RegisterConnection(rcRemote.OnClientEvent:Connect(function(...)
            local args = {...}
            pcall(function()
                local role = tostring(args[1] or "Unknown")
                -- Store our role as pseudo-team data
                TeamData["__myRole"] = role
                AddKillFeedEntry("Role: " .. role, Color3.fromRGB(200, 150, 255))
            end)
        end))
    end
end)

-- ============================================
-- Death Detection (Humanoid backup)
-- ============================================
task.spawn(function()
    local function hookHumanoid()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        IsAlive = hum.Health > 0
        RegisterConnection(hum.Died:Connect(function()
            IsAlive = false
            DeathTime = tick()
        end))
    end
    hookHumanoid()
    RegisterConnection(LocalPlayer.CharacterAdded:Connect(function()
        IsAlive = true
        LockedTarget = nil
        LockedCharacter = nil
        task.wait(0.5)
        hookHumanoid()
    end))
end)

-- Auto-Respawn Loop
task.spawn(function()
    while true do
        if Config.AutoRespawn and not IsAlive and (tick() - DeathTime) > 2 then
            pcall(function()
                local r = SafeFind(ReplicatedStorage, "Remote", "GameService", "Respawn")
                if r and r:IsA("RemoteEvent") then
                    r:FireServer()
                    AddKillFeedEntry("Auto-Respawn", Color3.fromRGB(50, 255, 200))
                end
            end)
            task.wait(3)
        end
        task.wait(0.5)
    end
end)

