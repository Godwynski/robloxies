local Camera = workspace.CurrentCamera

if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- ============================================
-- Configuration
-- ============================================
local Config = {
    -- Aim Core
    AutoAimEnabled = false,
    ViewAngle = 200,
    Smoothing = 5,
    FocusPoint = "HumanoidRootPart",
    TrackingMethod = "Camera", -- "Mouse" or "Camera"
    TargetMode = "Both",       -- "Players", "NPCs", "Both"
    TeamCheck = true,
    WallCheck = true,
    -- Aim Advanced
    StickyTarget = true,         -- Lock target until dead/gone
    Prediction = false,          -- Lead moving targets
    PredictionScale = 0.08,      -- Velocity multiplier for lead
    PriorityMode = "Distance",   -- "Distance" | "LowHP" | "Closest3D"
    -- Features
    DiagnosticsEnabled = false,
    AutoRespawn = false,
    KillFeedEnabled = true,
    TargetInfoEnabled = true,
    RemoteLogEnabled = false,
    -- ESP
    ESPEnabled = false,
    ESPBoxes = true,
    ESPNames = true,
    ESPHealth = true,
    ESPDistance = true,
    ESPTracers = false,
    ESPMaxDist = 1000,         -- Max render distance in studs
    ESPTeamColor = true,       -- Color by team (green=ally, red=enemy)
    -- Target Nearest
    NearestTargetKey = Enum.KeyCode.T,  -- Keybind to snap to nearest
}

-- ============================================
-- State
-- ============================================
local LockedTarget = nil
local LockedCharacter = nil
local KillFeedEntries = {}
local RemoteLog = {}
local DeathTime = 0
local IsAlive = true
local HitMarkerTime = 0
local KillCount = 0
local DeathCount = 0
local AssistCount = 0

-- ESP object pools: ESPCache[player] = {box, name, healthBG, healthFill, dist, tracer}
local ESPCache = {}

-- Team data captured from TeamService.UpdateData remote
-- TeamData[playerName] = teamId (string/number)
local TeamData = {}
local TeamDataRaw = {} -- Raw args for inspection

-- ============================================
-- Utility
-- ============================================
local function SafeFind(parent, ...)
    local current = parent
    for _, name in ipairs({...}) do
        if not current then return nil end
        current = current:FindFirstChild(name)
    end
    return current
end

-- ============================================
-- NPC Cache
-- ============================================
local NPCCache = {}
task.spawn(function()
    while true do
        if Config.TargetMode == "NPCs" or Config.TargetMode == "Both" then
            local newCache = {}
            local count = 0
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj ~= LocalPlayer.Character then
                    if not Players:GetPlayerFromCharacter(obj) then
                        local hum = obj:FindFirstChildOfClass("Humanoid")
                        if hum then table.insert(newCache, obj) end
                    end
                end
                count = count + 1
                if count % 1000 == 0 then task.wait() end
            end
            NPCCache = newCache
            task.wait(3)
        else
            task.wait(1)
        end
    end
end)

-- ============================================
-- Connection Manager
-- ============================================
local ActiveConnections = {}
local function RegisterConnection(conn)
    table.insert(ActiveConnections, conn)
    return conn
end

