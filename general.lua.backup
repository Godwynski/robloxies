CreateButton("🔍 Scan Teams (IN MATCH)", function(btn)
    local origText, origColor = btn.Text, btn.BackgroundColor3
    btn.Text = "Scanning..."; btn.BackgroundColor3 = Color3.fromRGB(150,150,50)
    task.wait(0.1)

    local r = string.rep("=", 50) .. "\n"
    r = r .. "TEAM DETECTION DEEP SCAN\n"
    r = r .. "Run this DURING a team match (TDM/etc) for best results\n"
    r = r .. string.rep("=", 50) .. "\n\n"

    -- Section 1: TeamService.UpdateData captured data
    r = r .. "[ CAPTURED TeamService.UpdateData ]\n"
    if next(TeamData) then
        for k, v in pairs(TeamData) do
            r = r .. string.format("  %s = %s\n", tostring(k), tostring(v))
        end
    else
        r = r .. "  No data captured yet. Join a team match first.\n"
    end
    r = r .. "\n  Raw arg count: " .. #TeamDataRaw .. "\n"
    if #TeamDataRaw > 0 then
        for i, arg in ipairs(TeamDataRaw) do
            if type(arg) == "table" then
                local entryCount = 0
                for _ in pairs(arg) do entryCount = entryCount + 1 end
                r = r .. string.format("  Arg[%d] = table with %d entries:\n", i, entryCount)
                local c = 0
                for k2, v2 in pairs(arg) do
                    r = r .. string.format("    [%s] (%s) = %s (%s)\n", tostring(k2), type(k2), tostring(v2), type(v2))
                    c = c + 1
                    if c >= 30 then r = r .. "    ... truncated\n"; break end
                end
            else
                r = r .. string.format("  Arg[%d] = %s (%s)\n", i, tostring(arg), type(arg))
            end
        end
    end
    r = r .. "\n"

    -- Section 2: Per-player deep comparison
    r = r .. "[ PLAYER COMPARISON ]\n"
    r = r .. string.format("  %-20s | %-12s | %-12s | %-20s | Attributes\n", "Name", "RobloxTeam", "Parent", "Tags")
    r = r .. "  " .. string.rep("-", 100) .. "\n"

    local myChar = LocalPlayer.Character
    local allPlayers = Players:GetPlayers()

    for _, plr in ipairs(allPlayers) do
        local char = plr.Character
        if not char then continue end

        local teamName = plr.Team and plr.Team.Name or "None"
        local parentName = char.Parent and char.Parent.Name or "nil"
        local tags = CollectionService:GetTags(char)
        local tagStr = #tags > 0 and table.concat(tags, ",") or "None"

        -- All attributes
        local attrStr = ""
        local attrs = char:GetAttributes()
        for k, v in pairs(attrs) do
            attrStr = attrStr .. k .. "=" .. tostring(v) .. " "
        end
        if attrStr == "" then attrStr = "None" end

        local marker = plr == LocalPlayer and " (YOU)" or ""
        r = r .. string.format("  %-20s | %-12s | %-12s | %-20s | %s%s\n",
            plr.Name, teamName, parentName, tagStr, attrStr, marker)
    end
    r = r .. "\n"

    -- Section 3: Character hierarchy differences
    r = r .. "[ CHARACTER PARENT HIERARCHY ]\n"
    for _, plr in ipairs(allPlayers) do
        local char = plr.Character
        if not char then continue end
        local path = ""
        local current = char
        for i = 1, 5 do
            if not current then break end
            path = path .. (path ~= "" and " ← " or "") .. current.Name .. " [" .. current.ClassName .. "]"
            current = current.Parent
        end
        r = r .. "  " .. plr.Name .. ": " .. path .. "\n"
    end
    r = r .. "\n"

    -- Section 4: Scan for team-like children in character models
    r = r .. "[ TEAM-LIKE CHILDREN IN CHARACTERS ]\n"
    local teamKeywords = {"team", "faction", "side", "role", "group", "squad", "color", "ally", "enemy"}
    for _, plr in ipairs(allPlayers) do
        local char = plr.Character
        if not char then continue end
        local found = {}
        for _, child in ipairs(char:GetDescendants()) do
            local lowerName = child.Name:lower()
            for _, kw in ipairs(teamKeywords) do
                if lowerName:find(kw) then
                    local val = ""
                    if child:IsA("ValueBase") then val = " = " .. tostring(child.Value) end
                    table.insert(found, child.Name .. " [" .. child.ClassName .. "]" .. val)
                    break
                end
            end
        end
        if #found > 0 then
            r = r .. "  " .. plr.Name .. ":\n"
            for _, f in ipairs(found) do r = r .. "    - " .. f .. "\n" end
        end
    end
    r = r .. "\n"

    -- Section 5: Scan DataReplica values
    r = r .. "[ PLAYER ATTRIBUTES ON PLAYER OBJECTS ]\n"
    for _, plr in ipairs(allPlayers) do
        local attrs = plr:GetAttributes()
        local attrStr = ""
        for k, v in pairs(attrs) do
            attrStr = attrStr .. k .. "=" .. tostring(v) .. " "
        end
        if attrStr ~= "" then
            r = r .. "  " .. plr.Name .. ": " .. attrStr .. "\n"
        end
    end
    r = r .. "\n"

    -- Section 6: BillboardGui / overhead team indicators
    r = r .. "[ OVERHEAD GUI / BILLBOARDGUI ]\n"
    for _, plr in ipairs(allPlayers) do
        local char = plr.Character
        if not char or not char:FindFirstChild("Head") then continue end
        local head = char.Head
        local billboards = {}
        for _, child in ipairs(head:GetChildren()) do
            if child:IsA("BillboardGui") then
                local texts = {}
                for _, desc in ipairs(child:GetDescendants()) do
                    if desc:IsA("TextLabel") and desc.Text ~= "" then
                        table.insert(texts, desc.Text:sub(1, 50))
                    end
                end
                table.insert(billboards, child.Name .. ": " .. table.concat(texts, " | "))
            end
        end
        if #billboards > 0 then
            r = r .. "  " .. plr.Name .. ":\n"
            for _, b in ipairs(billboards) do r = r .. "    - " .. b .. "\n" end
        end
    end
    r = r .. "\n"

    -- Section 7: Highlight objects (game uses HighlightHolder)
    r = r .. "[ HIGHLIGHT / TEAM COLORS ]\n"
    for _, plr in ipairs(allPlayers) do
        local char = plr.Character
        if not char then continue end
        for _, desc in ipairs(char:GetDescendants()) do
            if desc:IsA("Highlight") then
                r = r .. string.format("  %s: FillColor=%s OutlineColor=%s FillTransparency=%.2f\n",
                    plr.Name, tostring(desc.FillColor), tostring(desc.OutlineColor), desc.FillTransparency)
            end
        end
        -- Also check parent container for highlights
        if char.Parent then
            for _, sibling in ipairs(char.Parent:GetChildren()) do
                if sibling:IsA("Highlight") then
                    r = r .. string.format("  %s (parent): FillColor=%s OutlineColor=%s\n",
                        plr.Name, tostring(sibling.FillColor), tostring(sibling.OutlineColor))
                end
            end
        end
    end

    if setclipboard then
        pcall(function() setclipboard(r) end)
        btn.Text = "Copied!"; btn.BackgroundColor3 = Color3.fromRGB(50,150,50)
    else btn.Text = "No clipboard!"; btn.BackgroundColor3 = Color3.fromRGB(150,50,50) end
    task.delay(2, function() btn.Text = origText; btn.BackgroundColor3 = origColor end)
end)

-- ============================================
-- Aim Logic (must be above ESP & SnapToNearest)
-- ============================================
local function HasLoS(part)
    if not Config.WallCheck then return true end
    local cam = workspace.CurrentCamera
    if not cam then return true end
    local ray = RaycastParams.new()
    ray.FilterDescendantsInstances = {LocalPlayer.Character}
    ray.FilterType = Enum.RaycastFilterType.Exclude
    local origin = cam.CFrame.Position
    local dir = part.Position - origin
    local res = workspace:Raycast(origin, dir, ray)
    if not res then return true end -- Nothing hit, clear LoS
    return res.Instance:IsDescendantOf(part.Parent)
end

local function IsValidTarget(char)
    if not char or not char.Parent then return false end

    -- vc_Visible attribute: game-level visibility flag
    local vcVisible = char:GetAttribute("vc_Visible")
    if vcVisible == false then return false end

    -- Standard health check (fallback when vc_Visible isn't set)
    if vcVisible == nil then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return false end
    end

    -- ForceField = invulnerable
    if char:FindFirstChildOfClass("ForceField") then return false end

    -- Must have an aimable part
    local part = char:FindFirstChild(Config.FocusPoint) or char:FindFirstChild("HumanoidRootPart")
    if not part then return false end

    return true
end

local function IsEnemy(char)
    local function checkHighlight(hl)
        if not hl or not hl:IsA("Highlight") then return false end
        -- Ensure Adornee is valid if present
        if hl.Adornee and hl.Adornee ~= char and not hl.Adornee:IsDescendantOf(char) then
            return false
        end
        local c1, c2 = hl.OutlineColor, hl.FillColor
        -- Check if it's prominently red (R > 0.5, G < 0.5, B < 0.5)
        if (c1.R > 0.5 and c1.G < 0.5 and c1.B < 0.5) or 
           (c2.R > 0.5 and c2.G < 0.5 and c2.B < 0.5) then
            return true
        end
        return false
    end

    -- 1. Check inside character
    for _, desc in ipairs(char:GetDescendants()) do
        if checkHighlight(desc) then return true end
    end
    
    -- 2. Check parent folder/model
    if char.Parent then
        for _, child in ipairs(char.Parent:GetChildren()) do
            if checkHighlight(child) then return true end
        end
    end
    
    -- 3. Check Workspace for disconnected Highlights targeting this char
    local hlFolder = workspace:FindFirstChild("Highlight")
    if hlFolder then
        for _, hl in ipairs(hlFolder:GetDescendants()) do
            if hl:IsA("Highlight") and hl.Adornee then
                if hl.Adornee == char or hl.Adornee:IsDescendantOf(char) then
                    if checkHighlight(hl) then return true end
                end
            end
        end
    end

    return false
end

local function IsSameTeam(charA, charB)
    if not Config.TeamCheck then return false end

    -- 1. "All the players with red outline are the enemy"
    -- If the target (charB) has a red highlight, they are an enemy.
    if IsEnemy(charB) then
        return false
    end

    -- 2. If they don't have a red outline, they are an ally.
    return true
end

-- ============================================
-- ESP System
-- ============================================
local function CreateESPDrawings()
    local box = Drawing.new("Square")
    box.Visible = false; box.Color = Color3.fromRGB(255, 50, 50)
    box.Thickness = 1.5; box.Filled = false

    local nameTag = Drawing.new("Text")
    nameTag.Visible = false; nameTag.Size = 13
    nameTag.Color = Color3.new(1,1,1); nameTag.Outline = true
    nameTag.Center = true; nameTag.Text = ""

    local healthBG = Drawing.new("Square")
    healthBG.Visible = false; healthBG.Color = Color3.fromRGB(30,30,30)
    healthBG.Filled = true; healthBG.Transparency = 0.5

    local healthFill = Drawing.new("Square")
    healthFill.Visible = false; healthFill.Color = Color3.fromRGB(50,200,50)
    healthFill.Filled = true

    local distTag = Drawing.new("Text")
    distTag.Visible = false; distTag.Size = 12
    distTag.Color = Color3.fromRGB(200,200,200); distTag.Outline = true
    distTag.Center = true; distTag.Text = ""

    local tracer = Drawing.new("Line")
    tracer.Visible = false; tracer.Color = Color3.fromRGB(255,50,50)
    tracer.Thickness = 1

    return {
        box = box, name = nameTag, healthBG = healthBG,
        healthFill = healthFill, dist = distTag, tracer = tracer
    }
end

local function RemoveESPDrawings(cache)
    for _, d in pairs(cache) do pcall(function() d:Remove() end) end
end

local function HideESPDrawings(cache)
    for _, d in pairs(cache) do pcall(function() d.Visible = false end) end
end

local function UpdateESP()
    if not Config.ESPEnabled then return end

    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local viewport = Camera.ViewportSize

    local activeModels = {}
    local targets = {}

    if Config.TargetMode == "Players" or Config.TargetMode == "Both" then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                table.insert(targets, {char = plr.Character, name = plr.DisplayName or plr.Name})
            end
        end
    end
    if Config.TargetMode == "NPCs" or Config.TargetMode == "Both" then
        for _, npc in ipairs(NPCCache) do
            if npc and npc.Parent then
                table.insert(targets, {char = npc, name = npc.Name})
            end
        end
    end

    for _, data in ipairs(targets) do
        local char = data.char
        activeModels[char] = true

        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not root then
            if ESPCache[char] then HideESPDrawings(ESPCache[char]) end
            continue
        end

        -- vc_Visible check
        local vcVisible = char:GetAttribute("vc_Visible")
        if vcVisible == false then
            if ESPCache[char] then HideESPDrawings(ESPCache[char]) end
            continue
        end
        if vcVisible == nil and hum and hum.Health <= 0 then
            if ESPCache[char] then HideESPDrawings(ESPCache[char]) end
            continue
        end

        -- Distance check
        local dist3D = myRoot and (root.Position - myRoot.Position).Magnitude or 0
        if dist3D > Config.ESPMaxDist then
            if ESPCache[char] then HideESPDrawings(ESPCache[char]) end
            continue
        end

        -- Screen position
        local sp, onScreen = Camera:WorldToScreenPoint(root.Position)
        if not onScreen then
            if ESPCache[char] then HideESPDrawings(ESPCache[char]) end
            continue
        end

        -- Create drawings if needed
        if not ESPCache[char] then
            ESPCache[char] = CreateESPDrawings()
        end
        local cache = ESPCache[char]

        -- Determine color
        local espColor = Color3.fromRGB(255, 50, 50) -- Red = enemy
        if Config.ESPTeamColor and myChar then
            if IsSameTeam(myChar, char) then
                espColor = Color3.fromRGB(50, 255, 50) -- Green = ally
            end
        end

        -- Calculate accurate 2D box perfectly framing the 3D player
        local cf = root.CFrame
        local size = Vector3.new(4, 5.5, 2) -- Standard R15 size
        local x, y, z = size.X/2, size.Y/2, size.Z/2
        
        local corners = {
            (cf * CFrame.new(x, y, z)).Position,
            (cf * CFrame.new(-x, y, z)).Position,
            (cf * CFrame.new(x, -y, z)).Position,
            (cf * CFrame.new(-x, -y, z)).Position,
            (cf * CFrame.new(x, y, -z)).Position,
            (cf * CFrame.new(-x, y, -z)).Position,
            (cf * CFrame.new(x, -y, -z)).Position,
            (cf * CFrame.new(-x, -y, -z)).Position,
        }
        
        local minX, minY = math.huge, math.huge
        local maxX, maxY = -math.huge, -math.huge
        
        for _, pt in ipairs(corners) do
            local ptSp = Camera:WorldToScreenPoint(pt)
            if ptSp.X < minX then minX = ptSp.X end
            if ptSp.X > maxX then maxX = ptSp.X end
            if ptSp.Y < minY then minY = ptSp.Y end
            if ptSp.Y > maxY then maxY = ptSp.Y end
        end
        
        local boxW = maxX - minX
        local boxH = maxY - minY
        local boxX = minX
        local boxY = minY

        -- Box
        if Config.ESPBoxes then
            cache.box.Size = Vector2.new(boxW, boxH)
            cache.box.Position = Vector2.new(boxX, boxY)
            cache.box.Color = espColor
            cache.box.Visible = true
        else
            cache.box.Visible = false
        end

        -- Name
        if Config.ESPNames then
            cache.name.Text = data.name
            cache.name.Position = Vector2.new(sp.X, boxY - 16)
            cache.name.Color = espColor
            cache.name.Visible = true
        else
            cache.name.Visible = false
        end

        -- Health bar (left side of box)
        if Config.ESPHealth then
            local hpPct = hum and math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1) or 1
            local barW = 3
            local barX = boxX - barW - 2

            cache.healthBG.Size = Vector2.new(barW, boxH)
            cache.healthBG.Position = Vector2.new(barX, boxY)
            cache.healthBG.Visible = true

            local fillH = boxH * hpPct
            cache.healthFill.Size = Vector2.new(barW, fillH)
            cache.healthFill.Position = Vector2.new(barX, boxY + (boxH - fillH))
            if hpPct > 0.6 then cache.healthFill.Color = Color3.fromRGB(50, 200, 50)
            elseif hpPct > 0.3 then cache.healthFill.Color = Color3.fromRGB(255, 200, 50)
            else cache.healthFill.Color = Color3.fromRGB(255, 60, 60) end
            cache.healthFill.Visible = true
        else
            cache.healthBG.Visible = false
            cache.healthFill.Visible = false
        end

        -- Distance tag
        if Config.ESPDistance then
            cache.dist.Text = string.format("%dm", math.floor(dist3D))
            cache.dist.Position = Vector2.new(sp.X, boxY + boxH + 2)
            cache.dist.Visible = true
        else
            cache.dist.Visible = false
        end

        -- Tracer (bottom center screen to target feet)
        if Config.ESPTracers then
            cache.tracer.From = Vector2.new(viewport.X / 2, viewport.Y)
            cache.tracer.To = Vector2.new(sp.X, boxY + boxH)
            cache.tracer.Color = espColor
            cache.tracer.Visible = true
        else
            cache.tracer.Visible = false
        end
    end

    -- Clean up ESP for models that are gone
    for model, cache in pairs(ESPCache) do
        if not activeModels[model] then
            RemoveESPDrawings(cache)
            ESPCache[model] = nil
        end
    end
end

-- ============================================
-- Target Nearest (snap to closest 3D player)
-- ============================================
local function SnapToNearest()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local bestPart, bestDist = nil, math.huge

    local targetsList = {}
    if Config.TargetMode == "Players" or Config.TargetMode == "Both" then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                table.insert(targetsList, plr.Character)
            end
        end
    end
    if Config.TargetMode == "NPCs" or Config.TargetMode == "Both" then
        for _, npc in ipairs(NPCCache) do
            if npc and npc.Parent then table.insert(targetsList, npc) end
        end
    end

    for _, char in ipairs(targetsList) do
        if not IsValidTarget(char) then continue end
        if IsSameTeam(myChar, char) then continue end

        local part = char:FindFirstChild(Config.FocusPoint) or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end

        local d = (part.Position - myRoot.Position).Magnitude
        if d < bestDist then
            bestDist = d
            bestPart = part
        end
    end

    if bestPart then
        LockedTarget = bestPart
        LockedCharacter = bestPart.Parent

        -- Instant snap camera
        local curCF = Camera.CFrame
        Camera.CFrame = CFrame.new(curCF.Position, bestPart.Position)

        AddKillFeedEntry("⚡ Snapped → " .. bestPart.Parent.Name .. string.format(" [%dm]", math.floor(bestDist)), Color3.fromRGB(255, 200, 50))
    end
end

local function GetTargetScore(char, part, mouseLoc)
    local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
    if not onScreen then return nil, math.huge end

    -- Also reject targets outside the actual viewport (on screen but off edges)
    local viewport = Camera.ViewportSize
    if screenPos.X < 0 or screenPos.X > viewport.X or screenPos.Y < 0 or screenPos.Y > viewport.Y then
        return nil, math.huge
    end

    local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mouseLoc).Magnitude
    if screenDist > Config.ViewAngle then return nil, math.huge end

    if Config.PriorityMode == "Distance" then
        return screenDist, screenDist
    elseif Config.PriorityMode == "LowHP" then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hp = hum and hum.Health or 100
        -- Lower HP = lower score = higher priority. Tie-break by screen distance.
        return hp + (screenDist * 0.01), screenDist
    elseif Config.PriorityMode == "Closest3D" then
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if myRoot then
            local dist3D = (part.Position - myRoot.Position).Magnitude
            return dist3D, screenDist
        end
        return screenDist, screenDist
    end
    return screenDist, screenDist
end

local function GetTarget()
    local mouseLoc = UserInputService:GetMouseLocation()
    local myChar = LocalPlayer.Character
    if not myChar then return nil, "No Character" end

    local debugState = "Scanning..."
    local validCount, inFOV = 0, 0

    -- Sticky target: check if current lock is still valid
    if Config.StickyTarget and LockedCharacter and LockedTarget then
        if IsValidTarget(LockedCharacter) and not IsSameTeam(myChar, LockedCharacter) then
            local part = LockedCharacter:FindFirstChild(Config.FocusPoint) or LockedCharacter:FindFirstChild("HumanoidRootPart")
            if part then
                local sp, onScreen = Camera:WorldToScreenPoint(part.Position)
                if not onScreen then
                    -- Target is behind camera, drop lock
                else
                    -- Viewport bounds check
                    local viewport = Camera.ViewportSize
                    local inViewport = sp.X >= 0 and sp.X <= viewport.X and sp.Y >= 0 and sp.Y <= viewport.Y
                    local dist = (Vector2.new(sp.X, sp.Y) - mouseLoc).Magnitude
                    if inViewport and dist <= Config.ViewAngle then
                        local inLoS = HasLoS(part)
                        if inLoS then
                            return part, "Locked!"
                        end
                    end
                end
            end
        end
        -- Lock is invalid, clear it
        LockedTarget = nil
        LockedCharacter = nil
    end

    -- Build target list
    local targetsList = {}
    if Config.TargetMode == "Players" or Config.TargetMode == "Both" then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                table.insert(targetsList, plr.Character)
            end
        end
    end
    if Config.TargetMode == "NPCs" or Config.TargetMode == "Both" then
        for _, npc in ipairs(NPCCache) do
            if npc and npc.Parent then table.insert(targetsList, npc) end
        end
    end

    local bestPart, bestScore = nil, math.huge

    for _, char in ipairs(targetsList) do
        if not IsValidTarget(char) then continue end
        if IsSameTeam(myChar, char) then continue end

        local part = char:FindFirstChild(Config.FocusPoint) or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end

        validCount = validCount + 1

        local score, screenDist = GetTargetScore(char, part, mouseLoc)
        if not score then continue end -- Off screen or out of FOV

        inFOV = inFOV + 1

        local vcVisible = char:GetAttribute("vc_Visible")
        local inLoS = HasLoS(part)

        if inLoS then
            if score < bestScore then
                bestScore = score
                bestPart = part
                debugState = "Locked!"
            end
        else
            if not bestPart then debugState = "Blocked by Wall" end
        end
    end

    if validCount == 0 then debugState = "No valid targets"
    elseif inFOV == 0 and not bestPart then debugState = "Nobody in FOV" end

    -- Set sticky lock
    if bestPart and Config.StickyTarget then
        LockedTarget = bestPart
        LockedCharacter = bestPart.Parent
    end

    return bestPart, debugState
end

-- ============================================
-- Diagnostics / Network
-- ============================================
local NetworkPing = 0
task.spawn(function()
    while true do
        pcall(function() NetworkPing = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        task.wait(1)
    end
end)

local LastFrame = tick()
local FPS = 0

-- ============================================
-- Main Render Loop
-- ============================================
RunService:BindToRenderStep("AutoAimLoop", Enum.RenderPriority.Camera.Value + 1, function()
    local now = tick()
    FPS = math.floor(1 / math.max(now - LastFrame, 0.001))
    LastFrame = now

    local mouseLoc = UserInputService:GetMouseLocation()
    local viewport = Camera.ViewportSize

    -- FOV Circle
    if FOVCircle then
        FOVCircle.Position = mouseLoc
        FOVCircle.Radius = Config.ViewAngle
    end

    -- Aim
    local target = nil
    local aimState = "Disabled"

    if Config.AutoAimEnabled then
        target, aimState = GetTarget()

        -- FOV circle color feedback
        if target then
            FOVCircle.Color = Color3.fromRGB(50, 255, 50) -- Green when locked
        else
            FOVCircle.Color = Color3.fromRGB(255, 255, 255) -- White when scanning
        end

        if target then
            -- Compute aim position (with optional prediction)
            local aimPos = target.Position
            if Config.Prediction then
                local vel = Vector3.zero
                pcall(function()
                    vel = target.AssemblyLinearVelocity or target.Velocity or Vector3.zero
                end)
                aimPos = aimPos + vel * Config.PredictionScale
            end

            if Config.TrackingMethod == "Mouse" then
                local sp, onScreen = Camera:WorldToScreenPoint(aimPos)
                if onScreen then
                    local dx = (sp.X - mouseLoc.X) / Config.Smoothing
                    local dy = (sp.Y - mouseLoc.Y) / Config.Smoothing
                    pcall(function() mousemoverel(dx, dy) end)
                end
            elseif Config.TrackingMethod == "Camera" then
                local curCF = Camera.CFrame
                local tgtCF = CFrame.new(curCF.Position, aimPos)
                local alpha = math.clamp(1 / Config.Smoothing, 0.01, 1)
                Camera.CFrame = curCF:Lerp(tgtCF, alpha)
            end
        end
    else
        FOVCircle.Color = Color3.fromRGB(255, 255, 255)
    end

    -- ESP Update
    if Config.ESPEnabled then
        pcall(UpdateESP)
    else
        -- Hide all ESP when disabled
        for _, cache in pairs(ESPCache) do
            HideESPDrawings(cache)
        end
    end

    -- Target Info HUD
    if Config.TargetInfoEnabled and target then
        local sp, onScreen = Camera:WorldToScreenPoint(target.Position)
        if onScreen then
            local char = target.Parent
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local name = char and char.Name or "?"
            local hp = hum and hum.Health or 0
            local maxHp = hum and hum.MaxHealth or 100
            local hpPct = math.clamp(hp / math.max(maxHp, 1), 0, 1)

            -- Distance
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and math.floor((target.Position - myRoot.Position).Magnitude) or 0

            TargetInfoText.Text = string.format("%s  [%dm]", name, dist)
            TargetInfoText.Position = Vector2.new(sp.X, sp.Y - 35)
            TargetInfoText.Visible = true

            -- Health bar
            local barW = 60
            local barH = 4
            TargetHealthBG.Size = Vector2.new(barW, barH)
            TargetHealthBG.Position = Vector2.new(sp.X - barW/2, sp.Y - 22)
            TargetHealthBG.Visible = true

            TargetHealthFill.Size = Vector2.new(barW * hpPct, barH)
            TargetHealthFill.Position = Vector2.new(sp.X - barW/2, sp.Y - 22)
            TargetHealthFill.Visible = true

            -- Health bar color
            if hpPct > 0.6 then TargetHealthFill.Color = Color3.fromRGB(50, 200, 50)
            elseif hpPct > 0.3 then TargetHealthFill.Color = Color3.fromRGB(255, 200, 50)
            else TargetHealthFill.Color = Color3.fromRGB(255, 60, 60) end

            -- Lock diamond indicator
            LockIndicator.Position = Vector2.new(sp.X, sp.Y)
            LockIndicator.Visible = true
        else
            TargetInfoText.Visible = false
            TargetHealthBG.Visible = false
            TargetHealthFill.Visible = false
            LockIndicator.Visible = false
        end
    else
        TargetInfoText.Visible = false
        TargetHealthBG.Visible = false
        TargetHealthFill.Visible = false
        LockIndicator.Visible = false
    end

    -- Hit Marker (fade after 0.3s)
    if (now - HitMarkerTime) < 0.3 then
        HitMarker.Position = Vector2.new(viewport.X / 2, viewport.Y / 2)
        HitMarker.Visible = true
    else
        HitMarker.Visible = false
    end

    -- Kill Feed (top-right, fade after 5s)
    if Config.KillFeedEnabled then
        local feedX = viewport.X - 20
        local feedY = 60
        for i, entry in ipairs(KillFeedEntries) do
            local d = KillFeedDrawings[i]
            if d then
                local age = now - entry.time
                if age < 5 then
                    d.Text = entry.text
                    d.Color = entry.color
                    d.Position = Vector2.new(feedX - d.TextBounds.X, feedY + (i-1) * 20)
                    d.Transparency = math.clamp(1 - ((age - 3.5) / 1.5), 0, 1)
                    d.Visible = true
                else
                    d.Visible = false
                end
            end
        end
        -- Hide unused
        for i = #KillFeedEntries + 1, MAX_KILLFEED do
            if KillFeedDrawings[i] then KillFeedDrawings[i].Visible = false end
        end
    else
        for _, d in ipairs(KillFeedDrawings) do d.Visible = false end
    end

    -- Diagnostics Overlay
    if Config.DiagnosticsEnabled and DiagnosticText then
        local camType = Camera and Camera.CameraType.Name or "?"
        local tgtStr = target and target.Parent.Name or "None"
        local tgtHP = "N/A"
        if target then
            local h = target.Parent and target.Parent:FindFirstChildOfClass("Humanoid")
            if h then tgtHP = string.format("%.0f/%.0f", h.Health, h.MaxHealth) end
        end

        local ws, jp, jh, ps = 0, 0, 0, "N/A"
        local lc = LocalPlayer.Character
        if lc then
            local h = lc:FindFirstChildOfClass("Humanoid")
            if h then
                ws = h.WalkSpeed; jp = h.JumpPower; jh = h.JumpHeight
                pcall(function() ps = h:GetState().Name end)
            end
        end

        local kda = string.format("K:%d D:%d A:%d", KillCount, DeathCount, AssistCount)

        DiagnosticText.Text = string.format(
            "--- Diagnostics ---\nFPS: %d | Ping: %d ms\nAim: %s | %s\nCam: %s | Track: %s\nTarget: %s (%s)\nPriority: %s | Sticky: %s\n--- Physics ---\nSpeed: %.1f | JP: %.1f | JH: %.1f\nState: %s | Gravity: %.1f\n--- Stats ---\n%s | Alive: %s",
            FPS, NetworkPing, aimState, Config.Prediction and "PRED" or "STD",
            camType, Config.TrackingMethod,
            tgtStr, tgtHP,
            Config.PriorityMode, Config.StickyTarget and "ON" or "OFF",
            ws, jp, jh, ps, workspace.Gravity,
            kda, IsAlive and "Yes" or "No"
        )
        DiagnosticText.Position = mouseLoc + Vector2.new(40, -60)
    else
        if DiagnosticText then DiagnosticText.Visible = false end
    end
end)

-- ============================================
-- Keybinds
-- ============================================
RegisterConnection(UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        MainContainer.Visible = not MainContainer.Visible
    elseif input.KeyCode == Config.NearestTargetKey then
        SnapToNearest()
    end
end))

print("⚡ Pure Auto-Aim v2 Loaded. RightShift = toggle UI | T = snap nearest")
print("   Features: ESP | Sticky Lock | Prediction | Kill Feed | Hit Marker | Auto-Respawn")